{
  "name": "webapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "dev:test": "vite --mode test",
    "dev:prod": "vite --mode production",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:dev": "vite build --mode development",
    "build:test": "vite build --mode test",
    "build:prod": "vite build --mode production",
    "build-only": "vite build",
    "preview": "vite preview",
    "preview:dev": "vite preview --mode development",
    "preview:test": "vite preview --mode test",
    "preview:prod": "vite preview --mode production",
    "type-check": "vue-tsc --build",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage.enabled true --coverage.provider v8 --coverage.reporter=text-summary --coverage.reporter=json-summary",
    "test:unit:coverage:scheduling": "VITEST_SCHEDULING_COVERAGE=1 vitest run src/views/scheduling/Dag.test.ts src/views/scheduling/DagDetail.test.ts src/views/scheduling/DagHistory.test.ts src/views/scheduling/Task.test.ts src/views/scheduling/TaskType.test.ts src/views/scheduling/Audit.test.ts src/api/scheduling.test.ts src/api/schedulingIdempotency.test.ts --coverage.enabled true --coverage.provider v8 --coverage.reporter=text-summary --coverage.reporter=json-summary --coverage.reportsDirectory coverage/scheduling",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:real": "playwright test -c playwright.real.config.ts",
    "test:e2e:real:headed": "playwright test -c playwright.real.config.ts --headed",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@bpmn-io/properties-panel": "^3.34.0",
    "ajv": "^8.17.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.13.2",
    "bpmn-js": "^18.9.1",
    "bpmn-js-i18n": "^2.3.0",
    "bpmn-js-properties-panel": "^5.43.0",
    "camunda-bpmn-moddle": "^7.0.1",
    "diagram-js-minimap": "^5.2.0",
    "jose": "^6.1.2",
    "oidc-client-ts": "^3.4.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-oxlint": "^1.30.0",
    "eslint-plugin-vue": "^10.6.2",
    "jiti": "^2.6.1",
    "jsdom": "^26.1.0",
    "less": "^4.4.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.30.0",
    "prettier": "^3.7.3",
    "rc-upload": "^4.11.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.5"
  }
}
