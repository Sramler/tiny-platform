# Copy to .env.e2e.local before running real E2E.
# playwright.real.config.ts loads .env.e2e.local automatically when present.
# Fill placeholders with dedicated automation identities only.
# Never commit real credentials, client secrets, or TOTP secrets.

# Runtime
E2E_FRONTEND_PORT=5173
E2E_BACKEND_PORT=9000
E2E_FRONTEND_BASE_URL=http://localhost:5173
E2E_BACKEND_BASE_URL=http://localhost:9000
E2E_BACKEND_PROFILE=e2e
E2E_ENABLE_OIDC_TRACE=false
E2E_USE_SQL_SEED=false

# Database settings used by Spring profile and auth bootstrap helpers
E2E_DB_HOST=127.0.0.1
E2E_DB_PORT=3306
E2E_DB_NAME=tiny_web
E2E_DB_USER=root
E2E_DB_PASSWORD=<mysql-password>

# Compatibility aliases used by existing SQL seed helpers
E2E_MYSQL_HOST=127.0.0.1
E2E_MYSQL_PORT=3306
E2E_MYSQL_DATABASE=tiny_web
E2E_MYSQL_USER=root
E2E_MYSQL_PASSWORD=<mysql-password>

# Authentication identity used by the current real E2E chain
E2E_TENANT_CODE=<automation-tenant-code>
E2E_USERNAME=<automation-admin-username>
E2E_PASSWORD=<automation-admin-password>
E2E_TOTP_SECRET=<base32-totp-secret>
E2E_OIDC_CLIENT_ID=vue-client

# Optional override when a deterministic one-time code is injected by CI
E2E_TOTP_CODE=

# Secondary identity used by dual-tenant cross-tenant real-link scenarios
E2E_TENANT_CODE_B=<automation-tenant-code-b>
E2E_USERNAME_B=<automation-admin-username-b>
E2E_PASSWORD_B=<automation-admin-password-b>
E2E_TOTP_SECRET_B=<base32-totp-secret-b>

# Optional override when CI injects a deterministic code for tenant B
E2E_TOTP_CODE_B=

# Bind identity used by MFA first-bind real-link (unbound TOTP user)
E2E_TENANT_CODE_BIND=<automation-tenant-code-for-bind-user-or-empty-to-fallback-main-tenant>
E2E_USERNAME_BIND=<automation-bind-username>
E2E_PASSWORD_BIND=<automation-bind-password>
